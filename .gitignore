# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
env/

# Pytest
.pytest_cache/

# Model checkpoints & replay data (large binary files)
*.pt
*.npz

# Compiled C++ extensions
*.pyd
*.so

# Training outputs (large, reproducible)
/results/
/runs/

# IDE
.vscode/
.idea/
pyrightconfig.json

# Paper drafts (unpublished)
paper/
proposal/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

